{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Frontend",
			"type": "shell",
			"command": "cd frontend && npm run build",
			"problemMatcher": [
				"$eslint-stylish"
			],
			"group": "build"
		},
		{
			"label": "Start Dev Server",
			"type": "shell",
			"command": "cd frontend ; npm run dev",
			"isBackground": true,
			"problemMatcher": [],
			"group": "none"
		}
	]
}