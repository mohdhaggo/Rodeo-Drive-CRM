# API Configuration
# Set to false for production to use AWS Amplify API
VITE_USE_LOCAL_API=false
VITE_LOCAL_API_URL=http://localhost:3001/api
# Set to false in production - all data should come from Amplify
VITE_USE_MOCK_DATA=false

# AWS Configuration (used when USE_LOCAL_API is false)
VITE_AWS_REGION=ap-southeast-1

# AI Chat Configuration (optional)
VITE_AI_MODEL=deepseek-coder:latest
VITE_AI_TEMPERATURE=0.7
VITE_AI_MAX_TOKENS=2000
